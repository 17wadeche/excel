{
  "name": "workbook-dashboard-addin",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/workbook-dashboard-addin.git"
  },
  "license": "MIT",
  "config": {
    "app_to_debug": "excel",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "lint": "office-addin-lint check",
    "lint:fix": "office-addin-lint fix",
    "prettier": "office-addin-lint prettier",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "watch": "webpack --mode development --watch",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run unit",
    "unit": "node scripts/run-unit-tests.js",
    "validate:manifest:prod": "node scripts/validate-manifest-env.js manifest.xml --production"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@fluentui/react-components": "^9.55.1",
    "@fluentui/react-icons": "^2.0.264",
    "@sgratzl/chartjs-chart-boxplot": "^4.4.5",
    "antd": "^6.3.7",
    "axios": "^1.16.0",
    "chart.js": "^4.5.1",
    "chartjs-adapter-moment": "^1.0.1",
    "chartjs-chart-box-and-violin-plot": "^4.0.0",
    "chartjs-chart-funnel": "^4.2.5",
    "chartjs-chart-treemap": "^3.1.0",
    "chartjs-plugin-annotation": "^3.1.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "chartjs-plugin-hierarchical": "^4.4.5",
    "chartjs-plugin-zoom": "^2.2.0",
    "core-js": "^3.36.0",
    "es6-promise": "^4.2.8",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lodash.isequal": "^4.5.0",
    "moment": "^2.30.1",
    "react": "^18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-chartjs-2": "^5.3.1",
    "react-color": "^2.19.3",
    "react-dom": "^18.2.0",
    "react-draggable": "^4.5.0",
    "react-frappe-gantt": "^0.2.3",
    "react-grid-layout": "^2.2.3",
    "react-resizable": "^3.1.3",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "regenerator-runtime": "^0.14.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.25.4",
    "@babel/preset-typescript": "^7.23.3",
    "@types/lodash.isequal": "^4.5.8",
    "@types/office-js": "^1.0.377",
    "@types/office-runtime": "^1.0.35",
    "@types/react": "^18.2.64",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-color": "^3.0.13",
    "@types/react-dom": "^18.2.21",
    "@types/react-resizable": "^3.0.8",
    "@types/webpack": "^5.28.5",
    "acorn": "^8.11.3",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.4",
    "eslint-plugin-office-addins": "^4.0.3",
    "eslint-plugin-react": "^7.28.0",
    "file-loader": "^6.2.0",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.0",
    "less": "^4.2.0",
    "less-loader": "^12.2.0",
    "office-addin-cli": "^2.0.3",
    "office-addin-debugging": "^6.0.3",
    "office-addin-dev-certs": "^2.0.3",
    "office-addin-lint": "^3.0.3",
    "office-addin-manifest": "^2.0.3",
    "office-addin-prettier-config": "^2.0.1",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.2",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "5.1.0"
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Edge versions",
    "last 2 Firefox versions",
    "last 2 Safari versions"
  ],
  "description": "Excel task pane add-in for creating workbook dashboards, reports, and Gantt views."
}
